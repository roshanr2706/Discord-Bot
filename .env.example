DISCORD_TOKEN=

EVENTS_CHANNEL_ID=
GOOGLE_CALENDAR_ID=
GOOGLE_CREDENTIALS_PATH=./config/credentials.json

SUMMARY_CHANNEL_ID=

AI_BACKEND=anthropic
ANTHROPIC_API_KEY=

# Max output tokens. Raise AI_SUMMARY_MAX_TOKENS if !summarize gets cut off.
# AI_SUMMARY_MAX_TOKENS=1000
# AI_MEMORY_MAX_TOKENS=600

# Ollama (self-hosted, free)
# AI_BACKEND=ollama
# OLLAMA_HOST: point at wherever Ollama runs. Use the machine's LAN IP if it's
# on a different PC (e.g. http://192.168.1.50:11434). That machine must run
# Ollama with OLLAMA_HOST=0.0.0.0:11434 and have port 11434 open in its firewall.
# If Ollama is on the same host as this bot's Docker container, use
# http://host.docker.internal:11434 instead of localhost.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=gemma3:4b
# Seconds to wait for a response. Raise it if the first call times out while
# the model loads, or on slow / CPU-only hardware. Default 300.
# OLLAMA_TIMEOUT=300
# Context window. Raise it if large !summarize requests come back garbled or
# too short — the default truncates long transcripts. Bigger = more RAM/VRAM.
# OLLAMA_NUM_CTX=8192

BOULDER_CHANNEL_ID=0
BOULDER_CHIME_CHANCE=0.25
